(--text-caption);color:var(--color-text-secondary);margin:0;line-height:1.6;}.s8-deco{position:absolute;bottom:0;right:0;width:320px;height:320px;opacity:0.06;pointer-events:none;}</style><div class=\"s8-header\"><div class=\"s8-accent-bar\"></div><h1 class=\"s8-title\">交通与基础设施</h1><span class=\"s8-subtitle\">Transport &amp; Infrastructure</span></div><span class=\"s8-section-tag\">背景研究</span><div class=\"s8-triptych\"><div class=\"s8-card\"><div class=\"s8-card-img\"><img src=\"asset:89a60525-db7b-4ad3-9bb2-a597ba30ec09\" alt=\"枢纽站点分布\"></div><div class=\"s8-card-label\"><div class=\"s8-card-dot\" style=\"background:var(--color-primary)\"></div><p class=\"s8-card-text\">枢纽站点分布</p></div></div><div class=\"s8-card\"><div class=\"s8-card-img\"><img src=\"asset:7bde5e0c-8262-4d2e-aa94-53f0d61b5319\" alt=\"外部交通网络\"></div><div class=\"s8-card-label\"><div class=\"s8-card-dot\" style=\"background:var(--color-accent)\"></div><p class=\"s8-card-text\">外部交通网络</p></div></div><div class=\"s8-card\"><div class=\"s8-card-img\"><img src=\"asset:1d1caceb-2ac9-418a-b6ca-7f0577c828dc\" alt=\"周边基础设施规划\"></div><div class=\"s8-card-label\"><div class=\"s8-card-dot\" style=\"background:var(--color-secondary)\"></div><p class=\"s8-card-text\">周边基础设施规划</p></div></div></div><div class=\"s8-bottom\"><div class=\"s8-info\"><svg class=\"s8-info-icon\" viewBox=\"0 0 36 36\"><circle cx=\"18\" cy=\"18\" r=\"16\" fill=\"none\" stroke=\"var(--color-primary)\" stroke-width=\"1.5\"/><circle cx=\"18\" cy=\"18\" r=\"4\" fill=\"var(--color-primary)\"/><line x1=\"18\" y1=\"2\" x2=\"18\" y2=\"10\" stroke=\"var(--color-primary)\" stroke-width=\"1.5\"/><line x1=\"18\" y1=\"26\" x2=\"18\" y2=\"34\" stroke=\"var(--color-primary)\" stroke-width=\"1.5\"/><line x1=\"2\" y1=\"18\" x2=\"10\" y2=\"18\" stroke=\"var(--color-primary)\" stroke-width=\"1.5\"/><line x1=\"26\" y1=\"18\" x2=\"34\" y2=\"18\" stroke=\"var(--color-primary)\" stroke-width=\"1.5\"/></svg><div class=\"s8-info-content\"><h4>公交枢纽密集</h4><p>场地周边1公里范围内覆盖多条公交线路及站点，公共交通出行便捷高效</p></div></div><div class=\"s8-info\"><svg class=\"s8-info-icon\" viewBox=\"0 0 36 36\"><rect x=\"4\" y=\"14\" width=\"28\" height=\"12\" rx=\"3\" fill=\"none\" stroke=\"var(--color-accent)\" stroke-width=\"1.5\"/><line x1=\"10\" y1=\"14\" x2=\"10\" y2=\"8\" stroke=\"var(--color-accent)\" stroke-width=\"1.5\"/><line x1=\"26\" y1=\"14\" x2=\"26\" y2=\"8\" stroke=\"var(--color-accent)\" stroke-width=\"1.5\"/><line x1=\"8\" y1=\"8\" x2=\"28\" y2=\"8\" stroke=\"var(--color-accent)\" stroke-width=\"1.5\"/><circle cx=\"11\" cy=\"26\" r=\"3\" fill=\"none\" stroke=\"var(--color-accent)\" stroke-width=\"1.5\"/><circle cx=\"25\" cy=\"26\" r=\"3\" fill=\"none\" stroke=\"var(--color-accent)\" stroke-width=\"1.5\"/></svg><div class=\"s8-info-content\"><h4>区域交通网络完善</h4><p>十堰市高速路网与城市快速路环绕，场地可达性强，辐射鄂西北核心区域</p></div></div><div class=\"s8-info\"><svg class=\"s8-info-icon\" viewBox=\"0 0 36 36\"><rect x=\"6\" y=\"10\" width=\"24\" height=\"20\" rx=\"2\" fill=\"none\" stroke=\"var(--color-secondary)\" stroke-width=\"1.5\"/><polygon points=\"18,4 4,14 32,14\" fill=\"none\" stroke=\"var(--color-secondary)\" stroke-width=\"1.5\"/><rect x=\"14\" y=\"20\" width=\"8\" height=\"10\" fill=\"none\" stroke=\"var(--color-secondary)\" stroke-width=\"1.2\"/></svg><div class=\"s8-info-content\"><h4>基础设施规划同步</h4><p>周边市政道路、管网及公共服务设施规划同步推进，为文化建筑运营提供保障</p></div></div></div><svg class=\"s8-deco\" viewBox=\"0 0 320 320\"><circle cx=\"320\" cy=\"320\" r=\"280\" fill=\"none\" stroke=\"var(--color-primary)\" stroke-width=\"1.5\"/><circle cx=\"320\" cy=\"320\" r=\"220\" fill=\"none\" stroke=\"var(--color-primary)\" stroke-width=\"1\"/><circle cx=\"320\" cy=\"320\" r=\"160\" fill=\"none\" stroke=\"var(--color-primary)\" stroke-width=\"0.5\"/></svg></div>",
