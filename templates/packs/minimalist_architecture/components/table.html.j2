{% from "_chrome.html.j2" import chrome %}
<section class="slide table-slide{% if data.headers and data.headers|length > 6 %} wide{% endif %}"
         data-page="{{ page }}" data-section="{{ section }}">
  <style>
    .table-slide .wrap { flex: 1; min-height: 0; overflow: hidden;
                         display: flex; flex-direction: column;
                         margin-top: clamp(16px, 2.2vh, 24px); }
    .table-slide table { width: 100%; border-collapse: collapse; table-layout: fixed; }
    .table-slide thead tr { border-bottom: 2px solid var(--color-text-primary); }
    .table-slide th { text-align: left; font-weight: 700; color: var(--color-accent);
                      padding: clamp(10px, 1.6vh, 14px) clamp(10px, 1.3vw, 14px);
                      font-size: clamp(13px, 1.8vh, 16px);
                      text-transform: none; letter-spacing: 0.02em;
                      font-family: var(--font-heading);
                      border-bottom: 0; }
    .table-slide th::after {
      content: ""; display: block; width: clamp(14px, 1.2vw, 18px);
      height: 2px; background: var(--color-accent); margin-top: 6px; }
    .table-slide td { padding: clamp(10px, 1.6vh, 14px) clamp(10px, 1.3vw, 14px);
                      border-bottom: 1px solid var(--color-border); vertical-align: top;
                      font-size: clamp(13px, 1.78vh, 16px); line-height: 1.55;
                      color: var(--color-text-primary);
                      word-wrap: break-word; overflow-wrap: anywhere; }
    .table-slide tbody tr:nth-child(even) td { background: color-mix(in srgb, var(--color-border), transparent 50%); }
    .table-slide tbody tr:hover td { background: color-mix(in srgb, var(--color-accent), transparent 70%); opacity: 0.95; }
    .table-slide td:first-child { font-weight: 600; color: var(--color-accent); }
    .table-slide.wide th, .table-slide.wide td {
      font-size: clamp(11px, 1.45vh, 13px);
      padding: clamp(7px, 1.15vh, 10px) clamp(6px, 0.95vw, 9px);
      line-height: 1.45;
    }
    .table-slide .note { margin-top: auto; padding-top: clamp(12px, 1.8vh, 18px);
                         color: var(--color-text-secondary); font-size: clamp(11px, 1.4vh, 13px);
                         border-top: 1px dashed var(--color-border);
                         display: flex; align-items: baseline; gap: 8px; }
    .table-slide .note::before { content: "§"; font-family: var(--font-en);
                                  color: var(--color-accent); font-style: italic; }
    .table-slide .placeholder { color: var(--color-text-secondary); font-style: italic; padding: 24px; }
  </style>
  <h2>{{ data.title|e }}</h2>
  <div class="wrap">
    {% if data.headers and data.rows %}
    <table>
      <thead>
        <tr>{% for h in data.headers %}<th>{{ h|e }}</th>{% endfor %}</tr>
      </thead>
      <tbody>
        {% for row in data.rows %}
        <tr>{% for c in row %}<td>{{ c|e }}</td>{% endfor %}</tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
      <p class="placeholder">[table content pending]</p>
    {% endif %}
    {% if data.note %}<p class="note">{{ data.note|e }}</p>{% endif %}
  </div>
  {{ chrome(page, total_pages, section, section_en, project_title) }}
</section>
