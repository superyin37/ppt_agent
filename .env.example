# ──────────────────────────────────────────────────────────────
# PPT Agent — environment variables template
# Copy to `.env` and fill in local values. Never commit `.env`.
# ──────────────────────────────────────────────────────────────

# ── 数据库 ──
DATABASE_URL=postgresql://user:password@localhost:5432/ppt_agent
REDIS_URL=redis://localhost:6379/0

# ── LLM ──
ANTHROPIC_API_KEY=
LLM_STRONG_MODEL=claude-opus-4-6
LLM_FAST_MODEL=claude-sonnet-4-6
LLM_CRITIC_MODEL=google/gemini-3.1-pro-preview

# OpenRouter (优先于 Anthropic 直连，设置后自动切换)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── 地图 ──
AMAP_API_KEY=
AMAP_SECRET=

# ── 对象存储 ──
OSS_ENDPOINT=
OSS_BUCKET=ppt-agent-assets
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BASE_URL=

# ── 向量检索 ──
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIM=1536
EMBEDDING_PROVIDER=mock
OPENAI_API_KEY=
VOYAGE_API_KEY=
QWEN_API_KEY=
QWEN_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 渲染 ──
PLAYWRIGHT_HEADLESS=true
SLIDE_WIDTH_PX=1920
SLIDE_HEIGHT_PX=1080

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── 业务配置 ──
MAX_REPAIR_ATTEMPTS=3
MAX_SLIDES_PER_DECK=30
CASE_LIBRARY_MIN_SIZE=30
COMPOSER_MODE=html
DESIGN_REVIEW_GATE_ENABLED=true
DESIGN_REVIEW_MIN_SCORE=7.0
DESIGN_REVIEW_MIN_FOCAL_POINT=6.5
DESIGN_REVIEW_MIN_POLISH=6.5

# ── 概念渲染 (runninghub, see ADR-005) ──
# Set CONCEPT_RENDER_ENABLED=false to skip this stage entirely.
CONCEPT_RENDER_ENABLED=true
RUNNING_HUB_KEY=
RUNNING_HUB_BASE_URL=https://www.runninghub.cn
RUNNING_HUB_MODEL_PATH=/openapi/v2/rhart-image-n-g31-flash/image-to-image
RUNNING_HUB_QUERY_PATH=/openapi/v2/query
RUNNING_HUB_POLL_INTERVAL_SECONDS=3.0
RUNNING_HUB_POLL_TIMEOUT_SECONDS=360.0
RUNNING_HUB_GENERATION_RETRIES=2
# Local directory for downloaded concept images.
RUNNING_HUB_ASSET_DIR=D:/tmp/assets
